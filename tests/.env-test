# CloudTester Configuration
# This file controls test environment settings

# API Configuration
TEST_API_URL=http://localhost:8080
TEST_TIMEOUT=30

# GCP Project Configuration
TEST_PROJECT=test-project
TEST_REGION=us-central1
TEST_ZONE=us-central1-a

# Database Configuration
TEST_DB_PATH=/tmp/gcs-stimulator-test.db

# Optional: gcloud Configuration
# GCLOUD_PROJECT=test-project
# GCLOUD_REGION=us-central1

# Test Execution Options
# PYTEST_MARKERS=integration  # Run only integration tests
# PYTEST_PARALLEL=4           # Run 4 tests in parallel (requires pytest-xdist)
